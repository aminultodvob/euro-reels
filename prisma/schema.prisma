// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Reel {
  id        String   @id @default(cuid())
  title     String
  url       String   @unique
  category  String
  contentType ContentType @default(REEL)
  embedUrl  String
  thumbnail String?
  viewCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reels")
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  @@map("categories")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())

  @@map("users")
}

enum Role {
  ADMIN
}

enum ContentType {
  REEL
  POST
  VIDEO
}
